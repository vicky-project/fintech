{
  "name": "vicky-project/fintech-module",
  "type": "laravel-module",
  "license": "MIT",
  "description": "Financial Technology is a system digital finance as a personal assistance to your financial",
  "authors": [{
    "name": "Vicky Rahman",
    "email": "pratamavr@gmail.com"
  }],
  "extra": {
    "laravel": {
      "providers": [],
      "aliases": {}
    }
  },
  "require": {
    "php": "^8.2",
    "joshbrw/laravel-module-installer": "^1.0",
    "nnjeim/world": "^1.1",
    "elegantly/laravel-money": "^2.4",
    "smalot/pdfparser": "^2.12",
    "maatwebsite/excel": "^3.1",
    "dompdf/dompdf": "^3.1",
    "revolution/laravel-google-sheets": "^7.2",
    "mitoteam/jpgraph": "^10.5",
    "vicky-project/telegram-module": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "Modules\\FinTech\\": "app/",
      "Modules\\FinTech\\Database\\Factories\\": "database/factories/",
      "Modules\\FinTech\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Modules\\FinTech\\Tests\\": "tests/"
    }
  },
  "suggest": {
    "msoffcrypto-tool": "Diperlukan untuk mendekripsi file Excel yang terproteksi password"
  },
  "scripts": {
    "post-install-cmd": [
      "@php artisan package:discover --ansi",
      "Modules\\FinTech\\Composer\\CheckMsoffcrypto::check"
    ],
    "post-update-cmd": [
      "@php artisan package:discover --ansi",
      "Modules\\FinTech\\Composer\\CheckMsoffcrypto::check"
    ]
  }
}